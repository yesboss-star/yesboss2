# YesBoss API - Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins. Use * for all (dev only)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================
# AI Provider — xAI Grok (Primary)
# ============================================
XAI_API_KEY=xai-...
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-3

# Default AI provider used across all features
# Options: xai, openai, anthropic, gemini, qwen
DEFAULT_AI_PROVIDER=xai

# ============================================
# Web Scraping
# ============================================
FIRECRAWL_API_KEY=fc-...

# ============================================
# Supabase (Auth + Backend)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# ============================================
# MongoDB Atlas (Document Store)
# ============================================
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/yesboss?retryWrites=true&w=majority

# ============================================
# Qdrant Cloud (Vector Database)
# ============================================
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# ============================================
# Redis (Optional - for caching/queues)
# ============================================
REDIS_URL=redis://localhost:6379/0
