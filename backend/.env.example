# YesBoss API - Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins. Use * for all (dev only)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================
# AI Provider — xAI Grok (Primary)
# ============================================
XAI_API_KEY=xai-...
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-3

# Default AI provider used across all features
# Options: xai, openai, anthropic, gemini, qwen
DEFAULT_AI_PROVIDER=xai

# ============================================
# Web Scraping
# ============================================
FIRECRAWL_API_KEY=fc-...

# ============================================
# Supabase (Auth + Backend)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# ============================================
# MongoDB Atlas (Document Store)
# ============================================
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/yesboss?retryWrites=true&w=majority

# ============================================
# Qdrant Cloud (Vector Database)
# ============================================
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# ============================================
# SMTP Email Configuration (for OTP, password reset, notifications)
# ============================================
# Use your SMTP provider (Gmail, Zoho, SendGrid, etc.)
# For Gmail: enable 2FA and generate an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=YesBoss <your-email@gmail.com>
SMTP_USE_TLS=true

# ============================================
# Zoho Integration (OAuth2)
# ============================================
ZOHO_CLIENT_ID=1000.XXXX...
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REDIRECT_URI=http://localhost:8000/api/v1/zoho/callback
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_MAIL_API_URL=https://mail.zoho.com/api
ZOHO_CALENDAR_API_URL=https://calendar.zoho.com/api/v1

# ============================================
# Redis (Optional - for caching/queues)
# ============================================
REDIS_URL=redis://localhost:6379/0
