# ============================================
# AI Provider — xAI Grok (Primary)
# ============================================
XAI_API_KEY=your-xai-api-key
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-1-fast

# Default AI provider used across all features
DEFAULT_AI_PROVIDER=xai

# Firecrawl (Web Scraping)
FIRECRAWL_API_KEY=your-firecrawl-api-key

# SearAPI (Web Scraping)
SEAR_API_KEY=your-searapi-key

# Supabase
SUPABASE_URL=your-supabase-url
SUPABASE_KEY=your-supabase-key

# MongoDB
MONGODB_URI=your-mongodb-uri

# Qdrant
QDRANT_URL=your-qdrant-url
QDRANT_API_KEY=your-qdrant-api-key

# Firebase Admin
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Redis (Optional - for production)
REDIS_URL=redis://localhost:6379

# Environment
ENVIRONMENT=development

# Admin API Key (protects Swagger docs and admin endpoints)
ADMIN_API_KEY=your-admin-api-key

# Server
HOST=localhost
PORT=8000

# Email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Your App <your-email@gmail.com>

# Push notifications (VAPID keys)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_CLAIMS_EMAIL=admin@example.com

# Zoho API Integration
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REDIRECT_URI=http://localhost:8000/api/v1/zoho/callback
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_MAIL_API_URL=https://mail.zoho.com/api
ZOHO_CALENDAR_API_URL=https://calendar.zoho.com/api/v1
FRONTEND_URL=http://localhost:3000
