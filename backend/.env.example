# YesBoss API - Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins. Use * for all (dev only)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================
# AI Provider API Keys
# ============================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# Qwen / Ollama (local LLM)
QWEN_BASE_URL=http://localhost:11434/v1
QWEN_API_KEY=ollama
QWEN_MODEL=qwen2.5:14b

# ============================================
# Web Scraping
# ============================================
FIRECRAWL_API_KEY=fc-...

# ============================================
# Supabase (Auth + Backend)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# ============================================
# MongoDB Atlas (Document Store)
# ============================================
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/yesboss?retryWrites=true&w=majority

# ============================================
# Qdrant Cloud (Vector Database)
# ============================================
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# ============================================
# Redis (Optional - for caching/queues)
# ============================================
REDIS_URL=redis://localhost:6379/0
